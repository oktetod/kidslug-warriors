# ============================================================
#  KIDSLUG WARRIORS v2 -- Environment Variables
#  1. Copy this file:  cp .env.example .env.local
#  2. Fill in your Firebase values
#  3. NEVER commit .env.local to git
#  See FIREBASE_SETUP.md for full step-by-step instructions
# ============================================================

# ── FIREBASE PROJECT CONFIG ─────────────────────────────────
# Get from: Firebase Console > Project Settings > Your apps > Web
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── ADMIN UIDs (comma-separated) ────────────────────────────
# Get your UID from: Firebase Console > Authentication > Users
VITE_ADMIN_UIDS=your_firebase_uid_here

# ── PAYMENT VERIFICATION (Google Play Billing Cloud Function)
VITE_VERIFY_PURCHASE_URL=https://YOUR_REGION-YOUR_PROJECT.cloudfunctions.net/verifyPlayPurchase
